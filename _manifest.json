{
  "manifest_version": 2,
  "id": "kuuri-krtt.mai_tarots",
  "version": "1.0.1",
  "name": "麦麦塔罗",
  "description": "提供本地塔罗占卜功能，支持多种牌阵、牌面图片发送、AI 解读和语境化延伸评论。",
  "author": {
    "name": "kuuri-krtt",
    "url": "https://github.com/kuuri-krtt"
  },
  "license": "AGPL-v3.0",
  "urls": {
    "repository": "https://github.com/kuuri-krtt/Mai_tarots/",
    "homepage": "https://github.com/kuuri-krtt/",
    "documentation": "https://github.com/kuuri-krtt/Mai_tarots/#readme",
    "issues": "https://github.com/kuuri-krtt/Mai_tarots/issues"
  },
  "host_application": {
    "min_version": "1.0.5",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.5.2",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "send.image",
    "llm.generate"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "plugin_type": "extension",
  "display": {
    "icon": {
      "type": "local",
      "value": "./icon.png",
      "fallback": "puzzle"
    }
  }
}
